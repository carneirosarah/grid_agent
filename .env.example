# Copy this file to `.env` and fill in your key.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Model used by the planner. Any Gemini model with structured-output support works.
GEMINI_MODEL=gemini-3-flash-preview

# Optional: per-1M-token prices for the cost field on model_call trace
# events. Leave unset on the free tier (cost is recorded as 0).
# GEMINI_PRICE_INPUT_PER_1M=0.10
# GEMINI_PRICE_OUTPUT_PER_1M=0.40
